{
  "entities": {
    "User": {
      "title": "User",
      "description": "A member of the savings society.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the member."
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the member."
        },
        "isWinner": {
          "type": "boolean",
          "description": "Whether the member has won the lottery in the current cycle."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["name", "phone", "isWinner"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A daily deposit made by a member.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the payment."
        },
        "amount": {
          "type": "number",
          "description": "The amount deposited (usually 100)."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the payment (YYYY-MM-DD)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the payment was recorded."
        }
      },
      "required": ["userId", "amount", "date"]
    },
    "LotteryResult": {
      "title": "LotteryResult",
      "description": "The result of a lottery draw.",
      "type": "object",
      "properties": {
        "winnerId": {
          "type": "string",
          "description": "The ID of the winning user."
        },
        "amountWon": {
          "type": "number",
          "description": "The total amount won."
        },
        "drawDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time of the draw."
        }
      },
      "required": ["winnerId", "amountWon", "drawDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of society members."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of daily deposits."
    },
    "/lottery_results/{resultId}": {
      "schema": "LotteryResult",
      "description": "Collection of lottery draw results."
    },
    "/settings/{settingId}": {
      "schema": {
        "type": "object",
        "properties": {
          "societyName": { "type": "string" }
        }
      },
      "description": "Global application settings."
    }
  }
}
